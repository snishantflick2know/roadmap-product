{
  "cleanUrls": true,
  "functions": {
    "api/data.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/data", "dest": "/api/data.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
